import { describe, it, expect } from "vitest";
import {
  validateName,
  sanitizeName,
  validateRole,
  validateDeckInput,
  normalizeDeckInput,
  validateVote,
  validateRoomId,
  validateSessionId,
  validateSettingsUpdate,
  validateRoomTitle,
