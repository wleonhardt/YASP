<file path=".github/workflows/dependabot-automerge.yml">
name: Dependabot auto-merge

on:
  pull_request_target:
    branches: [main]
    types:
      - opened
      - reopened
      - synchronize
      - edited
      - labeled
      - unlabeled
      - ready_for_review

permissions:
  # Metadata-only workflow; contents read is sufficient because the GraphQL
  # auto-merge mutation is scoped via `pull-requests: write`.
  contents: read
  # Required to read PR metadata/files and mutate the PR auto-merge setting.
  pull-requests: write

concurrency:
  group: dependabot-automerge-${{ github.event.pull_request.number }}
  cancel-in-progress: true

jobs:
  enable-automerge:
    # Never run this workflow for human-authored PRs.
    if: github.event.pull_request.user.login == 'dependabot[bot]'
    runs-on: ubuntu-latest
    timeout-minutes: 5

    steps:
      # Fetch Dependabot's dependency metadata without checking out PR code.
      # This workflow intentionally stays metadata-only because
      # `pull_request_target` runs with a writable repo token.
      - name: Fetch Dependabot metadata
        id: dependabot-metadata
        uses: dependabot/fetch-metadata@21025c705c08248db411dc16f3619e6b5f9ea21a # v2
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}

      - name: Evaluate conservative eligibility
        id: evaluate
        uses: actions/github-script@f28e40c7f34bde8b3046d885e986cb6290c5673b # v7
        env:
          PACKAGE_ECOSYSTEM: ${{ steps.dependabot-metadata.outputs.package-ecosystem }}
          DEPENDENCY_NAMES: ${{ steps.dependabot-metadata.outputs.dependency-names }}
          DEPENDENCY_TYPE: ${{ steps.dependabot-metadata.outputs.dependency-type }}
          UPDATE_TYPE: ${{ steps.dependabot-metadata.outputs.update-type }}
        with:
          script: |
            const pr = context.payload.pull_request;
            const core = require('@actions/core');

            // Fail closed on any metadata we cannot reason about safely.
            const ecosystem = (process.env.PACKAGE_ECOSYSTEM || '').trim();
            const dependencyType = (process.env.DEPENDENCY_TYPE || '').trim();
            const updateType = (process.env.UPDATE_TYPE || '').trim();
            const dependencyNames = (process.env.DEPENDENCY_NAMES || '')
              .split(',')
              .map((name) => name.trim())
              .filter(Boolean);

            const changedFiles = await github.paginate(github.rest.pulls.listFiles, {
              owner: context.repo.owner,
              repo: context.repo.repo,
              pull_number: pr.number,
              per_page: 100,
            });

            const filenames = changedFiles.map((file) => file.filename);
            const labels = new Set((pr.labels || []).map((label) => label.name.toLowerCase()));
            const body = pr.body || '';
            const isSecurityUpdate =
              labels.has('security') ||
              /dependabot has resolved/i.test(body) ||
              /security update/i.test(pr.title || '');
            const isDevDependency = /development/i.test(dependencyType);
            const isPatchOrMinor = [
              'version-update:semver-patch',
              'version-update:semver-minor',
            ].includes(updateType);

            // Start conservative:
            // - single-dependency PRs only
            // - no majors
            // - no runtime/framework/lint-stack hotspots
            // - no CDK, Docker, or deploy workflow changes
            // - GitHub required checks still decide when/if GitHub merges
            const riskyPathPatterns = [
              /^cdk\//,
              /^Dockerfile$/,
              /^\.github\/workflows\/deploy-aws\.yml$/,
              /^\.github\/workflows\/docker-publish\.yml$/,
            ];
            const riskyDependencyPatterns = [
              /^react$/,
              /^react-dom$/,
              /^vite$/,
              /^vitest$/,
              /^typescript$/,
              /^eslint$/,
              /^@eslint\//,
              /^@typescript-eslint\//,
              /^eslint-plugin-/,
              /^i18next$/,
              /^react-i18next$/,
              /^fastify$/,
              /^@fastify\//,
              /^socket\.io$/,
              /^socket\.io-client$/,
              /^@socket\.io\//,
            ];

            const reasons = [];

            if (pr.draft) {
              reasons.push('draft PR');
            }

            if (!ecosystem) {
              reasons.push('missing Dependabot package ecosystem metadata');
            }

            if (!isPatchOrMinor) {
              reasons.push(`unsupported update type: ${updateType || 'unknown'}`);
            }

            if (dependencyNames.length !== 1) {
              reasons.push(
                `grouped or multi-dependency PR (${dependencyNames.length || 0} dependencies) stays manual`,
              );
            }

            if (ecosystem === 'docker') {
              reasons.push('docker ecosystem updates stay manual');
            }

            if (!['github-actions', 'npm'].includes(ecosystem)) {
              reasons.push(`ecosystem ${ecosystem || 'unknown'} is not in the auto-merge allowlist`);
            }

            const riskyFiles = filenames.filter((filename) =>
              riskyPathPatterns.some((pattern) => pattern.test(filename)),
            );
            if (riskyFiles.length > 0) {
              reasons.push(`touches risky path(s): ${riskyFiles.join(', ')}`);
            }

            const riskyDependencies = dependencyNames.filter((name) =>
              riskyDependencyPatterns.some((pattern) => pattern.test(name)),
            );
            if (riskyDependencies.length > 0) {
              reasons.push(`dependency denylist hit: ${riskyDependencies.join(', ')}`);
            }

            if (ecosystem === 'npm' && !isSecurityUpdate && !isDevDependency) {
              reasons.push('non-security npm PR is not a devDependency update');
            }

            const eligible = reasons.length === 0;
            const summary = [
              `ecosystem=${ecosystem || 'unknown'}`,
              `dependencyType=${dependencyType || 'unknown'}`,
              `updateType=${updateType || 'unknown'}`,
              `dependencies=${dependencyNames.join(', ') || 'unknown'}`,
              `securityUpdate=${isSecurityUpdate}`,
              `eligible=${eligible}`,
            ].join('\n');

            core.setOutput('eligible', eligible ? 'true' : 'false');
            core.setOutput('reason', reasons.length > 0 ? reasons.join('; ') : 'eligible');

            await core.summary
              .addHeading('Dependabot auto-merge evaluation')
              .addCodeBlock(summary, 'text')
              .addRaw(
                eligible
                  ? 'Eligible: GitHub auto-merge can be enabled and will still wait for required checks.'
                  : `Manual review required: ${reasons.join('; ')}`,
              )
              .write();

      - name: Enable GitHub auto-merge
        if: steps.evaluate.outputs.eligible == 'true'
        uses: actions/github-script@f28e40c7f34bde8b3046d885e986cb6290c5673b # v7
        with:
          script: |
            const pr = context.payload.pull_request;
            const core = require('@actions/core');

            try {
              await github.graphql(
                `
                  mutation EnableAutoMerge($pullRequestId: ID!) {
                    enablePullRequestAutoMerge(
                      input: {
                        pullRequestId: $pullRequestId
                        mergeMethod: SQUASH
                      }
                    ) {
                      pullRequest {
                        number
                        autoMergeRequest {
                          enabledAt
                        }
                      }
                    }
                  }
                `,
                { pullRequestId: pr.node_id },
              );
            } catch (error) {
              if (/already enabled/i.test(error.message)) {
                core.info('Auto-merge was already enabled for this PR.');
                return;
              }
              throw error;
            }

      - name: Disable GitHub auto-merge when PR is not eligible
        if: steps.evaluate.outputs.eligible != 'true'
        uses: actions/github-script@f28e40c7f34bde8b3046d885e986cb6290c5673b # v7
        with:
          script: |
            const pr = context.payload.pull_request;
            const core = require('@actions/core');

            if (!pr.auto_merge) {
              core.info('Auto-merge was not enabled, nothing to disable.');
              return;
            }

            try {
              await github.graphql(
                `
                  mutation DisableAutoMerge($pullRequestId: ID!) {
                    disablePullRequestAutoMerge(
                      input: {
                        pullRequestId: $pullRequestId
                      }
                    ) {
                      pullRequest {
                        number
                      }
                    }
                  }
                `,
                { pullRequestId: pr.node_id },
              );
            } catch (error) {
              if (/auto-merge is not enabled/i.test(error.message)) {
                core.info('Auto-merge was already disabled.');
                return;
              }
              throw error;
            }

      - name: Explain manual-review outcome
        if: steps.evaluate.outputs.eligible != 'true'
        run: |
          echo "Dependabot PR kept manual: ${{ steps.evaluate.outputs.reason }}"
</file>

<file path=".github/workflows/knip.yml">
# Knip: unused files, exports, and dependencies (advisory-only).
#
# Intentionally NOT a blocking gate. Knip's value is as a periodic
# janitor signal, not a merge gate — it routinely surfaces
# intentionally-unused internal API surface (tests-only exports,
# adapters kept for future backends, etc.). Running it as `continue-on-
# error` keeps the signal visible in the check summary without
# creating pressure to delete code that is about to be used.
#
# Promote to a hard gate only once the config is tuned to zero
# false-positives on main — see SECURITY_REMEDIATION_PLAN.md.
name: Knip (advisory)

on:
  pull_request:
  push:
    branches: [main]

permissions:
  contents: read

concurrency:
  group: knip-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  knip:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Check out repo
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6

      - name: Set up Node.js
        uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6
        with:
          node-version: 20
          cache: npm
          cache-dependency-path: package-lock.json

      - name: Install dependencies
        run: npm ci

      - name: Run knip (advisory)
        id: knip
        continue-on-error: true
        run: |
          echo "## Knip results (advisory, non-blocking)" >> "$GITHUB_STEP_SUMMARY"
          echo "" >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"
          set +e
          npx knip --no-progress | tee /tmp/knip.txt
          KNIP_EXIT=$?
          set -e
          cat /tmp/knip.txt >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"
          if [ "$KNIP_EXIT" -ne 0 ]; then
            echo "_Advisory: knip reported findings. Triage at leisure; this step does not block the PR._" >> "$GITHUB_STEP_SUMMARY"
          else
            echo "_Clean._" >> "$GITHUB_STEP_SUMMARY"
          fi
          exit "$KNIP_EXIT"
</file>

<file path=".github/workflows/lint-strict.yml">
# Type-aware ESLint strict pass (advisory-only).
#
# Enables `@typescript-eslint/no-unsafe-*` via YASP_LINT_STRICT=1. Kept
# advisory because the recommended-type-checked rules flag
# pre-existing any-flavored patterns across tests and adapters that
# the team has not yet triaged; making it blocking today would mean a
# large drive-by cleanup PR. The advisory run keeps the posture
# visible so the fallout can be burned down incrementally.
#
# Promote to a hard gate once `npm run lint:strict` is clean on main
# — tracked in SECURITY_REMEDIATION_PLAN.md.
name: Lint strict (advisory)

on:
  pull_request:
  push:
    branches: [main]

permissions:
  contents: read

concurrency:
  group: lint-strict-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  lint-strict:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Check out repo
        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6

      - name: Set up Node.js
        uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6
        with:
          node-version: 20
          cache: npm
          cache-dependency-path: package-lock.json

      - name: Install dependencies
        run: npm ci

      - name: Build shared (strict lint needs declarations)
        run: npm run build:shared

      - name: Run strict lint (advisory)
        id: strict
        continue-on-error: true
        run: |
          echo "## ESLint strict (type-aware, advisory)" >> "$GITHUB_STEP_SUMMARY"
          echo "" >> "$GITHUB_STEP_SUMMARY"
          echo '```' >> "$GITHUB_STEP_SUMMARY"
          set +e
          npm run lint:strict 2>&1 | tee /tmp/lint-strict.txt
          STRICT_EXIT=$?
          set -e
          tail -c 60000 /tmp/lint-strict.txt >> "$GITHUB_STEP_SUMMARY" || true
          echo '```' >> "$GITHUB_STEP_SUMMARY"
          if [ "$STRICT_EXIT" -ne 0 ]; then
            echo "_Advisory: strict lint reported issues. Not a merge gate; track incremental burn-down._" >> "$GITHUB_STEP_SUMMARY"
          else
            echo "_Clean — consider promoting strict lint to a hard gate._" >> "$GITHUB_STEP_SUMMARY"
          fi
          exit "$STRICT_EXIT"
</file>

<file path="cdk/bin/yasp.ts">
#!/usr/bin/env node
import * as cdk from "aws-cdk-lib";
import { YaspStack } from "../lib/yasp-stack";

const app = new cdk.App();

// Non-secret config from context with sensible defaults.
const ecrRepoName = app.node.tryGetContext("ecrRepoName") ?? "yasp";
const serviceName = app.node.tryGetContext("serviceName") ?? "yasp";
const createRepository = app.node.tryGetContext("createRepository") === "true";
const retainLogBucket = app.node.tryGetContext("retainLogBucket") === "true";
const enableBasicAuth = app.node.tryGetContext("enableBasicAuth") !== "false";
const instanceType = (app.node.tryGetContext("instanceType") as string | undefined) ?? "t3.micro";

// Image reference from context — exactly one of imageTag or imageDigest is required.
const imageTag = app.node.tryGetContext("imageTag") as string | undefined;
const imageDigest = app.node.tryGetContext("imageDigest") as string | undefined;

// Optional SNS topic ARN for alarm notifications.
const alarmTopicArn = app.node.tryGetContext("alarmTopicArn") as string | undefined;

// Optional custom domain(s). Accepts a single host or comma-separated list,
// e.g. `-c domainName=app.yasp.team,www.yasp.team`. Every name must be covered
// by the ACM certificate referenced by certificateArn (SANs or wildcard).
const domainNameContext = app.node.tryGetContext("domainName") as string | undefined;
const domainNames = domainNameContext
  ? domainNameContext
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean)
  : undefined;
const certificateArn = app.node.tryGetContext("certificateArn") as string | undefined;

new YaspStack(app, "YaspStack", {
  ecrRepoName,
  serviceName,
  createRepository,
  retainLogBucket,
  enableBasicAuth,
  imageTag,
  imageDigest,
  alarmTopicArn,
  instanceType,
  domainNames,
  certificateArn,
  env: {
    account: process.env.CDK_DEFAULT_ACCOUNT,
    region: process.env.CDK_DEFAULT_REGION,
  },
});
</file>

