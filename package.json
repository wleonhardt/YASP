{
  "name": "yasp",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "build:shared": "npm run build -w shared",
    "build:server": "npm run build -w server",
    "build:client": "npm run build -w client",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "test": "npm run test:scripts && npm run test -w server && npm run test -w client",
    "test:scripts": "node --test tests/scripts/check-i18n.test.mjs tests/scripts/check-ec2-bootstrap.test.mjs",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "i18n:check": "node scripts/check-i18n.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "npm run start -w server",
    "clean": "rm -rf shared/dist server/dist client/dist node_modules"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.23.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
